# ====== 生产环境配置（部署到 ECS 时复制为 .env 并填入真实值）======

# 数据库
DB_NAME=chankang_platform
DB_USER=chankang
DB_PASSWORD=请替换为强密码
DB_ROOT_PASSWORD=请替换为强root密码

# Redis
REDIS_PASSWORD=请替换为强密码

# JWT（≥32 位随机字符串，可用 `openssl rand -hex 32` 生成）
JWT_SECRET=请替换为长随机字符串
JWT_EXPIRES_IN=7d

# CORS 允许的源（IP 访问可留 *）
ALLOWED_ORIGINS=*

# 前端构建变量
VITE_API_BASE_URL=/api
