# API配置
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# 数据库配置（后端使用）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chankang_platform
DB_USER=root
DB_PASSWORD=your_password_here

# JWT配置
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d

# 阿里云配置
ALIYUN_REGION=cn-hangzhou
ALIYUN_ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ALIYUN_ECS_HOST=your_ecs_ip_here
ALIYUN_ECS_USER=root

# 邮件服务配置（如需要）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password

# 文件存储配置
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE=10485760

# Redis配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 开发环境配置
NODE_ENV=development

# File upload storage
# PUBLIC_BASE_URL can be empty when frontend and backend share one domain.
PUBLIC_BASE_URL=http://localhost
UPLOAD_DIR=/app/uploads
ALLOW_LOCAL_UPLOAD_FALLBACK=true

# OSS is optional. If these values are empty or OSS upload fails, files are stored in UPLOAD_DIR.
OSS_REGION=
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
